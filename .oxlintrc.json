{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "unicorn/no-invalid-fetch-options": "off"
  },
  "ignorePatterns": [".claude/**", "dist/**", "node_modules/**", "output/**"],
  "env": {
    "builtin": true
  }
}
